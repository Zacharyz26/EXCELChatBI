# ChatBI 环境变量样例 —— 复制为 .env 后填写真实值。
# 红线：禁止把真实密钥/连接串/模型名硬编码进代码，一律走此处。
# 模型名集中在 config/models.yaml（model registry），不在业务代码里写死。
#
# 本文件与 packages/common/config.py 的 Settings 字段一一对应；
# Settings 不读的变量不要往这里加（Dify/MCP_*_URL 等死变量已于 v2.1 清理）。

# ── 运行环境 ──
APP_ENV=development                     # development | staging | production
LOG_LEVEL=INFO

# ── 模型路由网关（OpenAI 兼容接口）──
MODEL_REGISTRY_PATH=config/models.yaml
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
# 多模态识图：Qwen2.5-VL / GLM-4V（按实际供应商填写 base/key）
VISION_API_BASE=
VISION_API_KEY=

# ── 本地数据落盘（当前存储形态；MinIO/PostgreSQL 未接，见设计文档 5.5）──
DATASET_DIR=.data/datasets
UPLOAD_DIR=.data/uploads
REPORT_DIR=.data/reports
CHAT_DB_PATH=.data/chatbi.db             # 项目/对话/消息/工件 SQLite 真相源
CONVERSATION_CACHE_SIZE=128              # 单进程最近对话 LRU 热缓存容量
CHAT_HISTORY_LIMIT=20                    # 每次模型请求携带的最近消息数
CHAT_PROFILE_MAX_CHARS=12000             # 常驻数据画像最大字符数，超出截断

# ── Agent 循环护栏（阶段3，初值见设计文档 14.5.1，按真实使用调优）──
AGENT_MAX_TOOL_CALLS=12                  # 单轮对话工具调用总数上限（6 会挡掉多指标出图的 3+3+3 计划）
AGENT_TOOL_RESULT_MAX_CHARS=6000         # 工具结果回填模型前的截断上限
AGENT_REGISTRY_MAX_ENTRIES=12            # 分析登记表全量条目上限，更旧的摘要化
MAX_UPLOAD_MB=50                        # 上传大小上限（超限 413，防内存 DoS）
LARGE_TABLE_ROW_THRESHOLD=500000        # 超过直接拒绝；大表 DuckDB 分块留后续

# ── 数据画像安全策略（缺失用内置宽松默认）──
DATA_POLICY_PATH=config/data_policy.yaml

# ── 中文 RAG（知识库检索）──
RAG_EMBEDDER=hashing                    # hashing（默认替身）| bge（bge-m3，需 uv sync --extra rag）
RAG_RERANKER=lexical                    # lexical（默认替身）| bge（bge-reranker-v2-m3）
RAG_STORE=local                         # local（JSON 落盘）| milvus（Milvus Lite；应与 bge 配对）
MILVUS_URI=.data/milvus_lite.db         # 本地文件=Milvus Lite；http://host:19530=standalone（只改此处）
MILVUS_TOKEN=                           # Standalone 鉴权 token（user:password）；Lite 留空
MILVUS_COLLECTION=kb_chunks             # 逻辑集合名；重建代际由程序管理，不要手工改后缀集合
EMBEDDING_DEVICE=auto                   # auto | cpu | cuda（决策4：切换不改代码）
RAG_MIN_RELEVANCE=0.0                   # 替身默认；bge 已验收配置使用 0.02（见验收基线文档）
EMBEDDING_DIM=256                       # HashingEmbedder 向量维度
KB_INDEX_DIR=.data/kb_index
KB_DOCS_DIR=docs/kb_samples
KB_BACKUP_DIR=.data/kb_backups             # Local/Lite 离线备份目录
KB_MAX_FILES=1000                       # 单次同步/重建最多读取的文档数
KB_MAX_DOCUMENT_CHARS=2000000           # 单文档字符上限
EMBEDDING_MODEL=BAAI/bge-m3             # HuggingFace 名称或离线权重目录
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── 图表服务端截图（留空自动探测已安装的 chromium）──
CHROMIUM_EXECUTABLE_PATH=

# ── 沙箱（红线5，实现选型待确认）──
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY_MB=512

# ── 预留（Settings 已定义但当前代码未接；接入触发条件见设计文档 13.2）──
REDIS_HOST=127.0.0.1                    # SQLite 已启用；多 worker/多实例时再引入 Redis
REDIS_PORT=6379
SESSION_TTL_SECONDS=3600
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
MILVUS_HOST=127.0.0.1                   # 预留；当前 standalone 连接统一使用 MILVUS_URI
MILVUS_PORT=19530
MINIO_ENDPOINT=127.0.0.1:9000
