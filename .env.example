# ChatBI 环境变量样例 —— 复制为 .env 后填写真实值。
# 红线：禁止把真实密钥 / 连接串 / 模型名硬编码进代码，一律走此处。
# 模型名集中在 config/models.example.yaml（model registry），不在业务代码里写死。

# ── 运行环境 ──
APP_ENV=development                     # development | staging | production
LOG_LEVEL=INFO

# ── 模型路由网关（OpenAI 兼容接口）──
# 核心推理：DeepSeek-V3 / DeepSeek-R1
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
# 多模态识图：Qwen2.5-VL / GLM-4V（按实际供应商填写 base/key）
VISION_API_BASE=
VISION_API_KEY=
# model registry 配置文件路径
MODEL_REGISTRY_PATH=config/models.yaml

# ── 向量库 Milvus（中文 RAG）──
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION=chatbi_kb

# ── Embedding / Rerank 模型（中文，禁用英文默认）──
EMBEDDING_MODEL=bge-large-zh-v1.5
RERANK_MODEL=bge-reranker-v2-m3

# ── Redis（会话状态 / 上下文缓存）──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SESSION_TTL_SECONDS=3600

# ── PostgreSQL（分析结果 / 图表元数据 / 报告）──
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=chatbi
POSTGRES_USER=chatbi
POSTGRES_PASSWORD=

# ── MinIO（Excel 原始文件 / 导出 PDF）──
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_BUCKET=chatbi

# ── 编排 A 轨 Dify ──
DIFY_API_BASE=
DIFY_API_KEY=

# ── MCP 工具服务地址（治理层统一接入）──
MCP_EXCEL_PARSER_URL=http://127.0.0.1:8101
MCP_STATS_URL=http://127.0.0.1:8102
MCP_CHART_URL=http://127.0.0.1:8103
MCP_REPORT_URL=http://127.0.0.1:8104
MCP_CODE_INTERPRETER_URL=http://127.0.0.1:8105

# ── 沙箱（红线5，具体实现选型待确认）──
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY_MB=512
