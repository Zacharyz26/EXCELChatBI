# ChatBI API 的知识库生产档；通过进程管理器/容器 env-file 注入，不要提交真实 token。
APP_ENV=production
LOG_LEVEL=INFO

RAG_EMBEDDER=bge
RAG_RERANKER=bge
RAG_STORE=milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=chatbi:replace-with-strong-password
MILVUS_COLLECTION=kb_chunks

EMBEDDING_DEVICE=cuda
EMBEDDING_MODEL=/srv/chatbi/models/bge-m3
RERANK_MODEL=/srv/chatbi/models/bge-reranker-v2-m3
RAG_MIN_RELEVANCE=0.02
HF_HUB_OFFLINE=1

KB_DOCS_DIR=/srv/chatbi/kb-docs
KB_MAX_FILES=1000
KB_MAX_DOCUMENT_CHARS=2000000
KB_BACKUP_DIR=/srv/chatbi/backups/kb
